{
  "name": "tenant-management-gateway",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/tenant-management-gateway/src",
  "projectType": "application",
  "prefix": "tenant-management-gateway",
  "tags": [],
  "generators": {},
  "targets": {
    "build": {
      "executor": "@nx/webpack:webpack",
      "options": {
        "webpackConfig": "apps/tenant-management-gateway/webpack.config.js",
        "outputPath": "dist/apps/tenant-management-gateway",
        "main": "apps/tenant-management-gateway/src/main.ts",
        "tsConfig": "apps/tenant-management-gateway/tsconfig.app.json",
        "assets": [],
        "target": "node",
        "compiler": "tsc",
        "babelUpwardRootMode": true
      },
      "configurations": {
        "production": {
          "optimization": true,
          "extractLicenses": true,
          "inspect": false,
          "fileReplacements": []
        }
      }
    },
    "serve": {
      "executor": "@nx/js:node",
      "options": {
        "buildTarget": "tenant-management-gateway:build"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@nx/jest:jest",
      "options": {
        "jestConfig": "apps/tenant-management-gateway/jest.config.ts",
        "runInBand": true
      }
    }
  }
}
