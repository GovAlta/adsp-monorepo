        "Partnership",
        "Corporation",
        "Non-Profit"
      ]
    },
    "contactEmail": {
      "type": "string",
      "format": "email",
      "minLength": 1
    },
    "contactPhone": {
      "type": "string",
      "minLength": 1
    },
    "province": {
      "type": "string",
      "enum": [
        ""
      ]
    },
    "products": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "productName": {
            "type": "string"
          },
          "category": {
            "type": "string",
            "enum": [
              "Produce",
              "Baked Goods",
              "Crafts",
              "Prepared Foods",
              "Other"
            ]
