# Environment variables for .github/scripts tooling
# Copy this file to .env.github-scripts and fill in your values.
# .env.github-scripts is gitignored — never commit real credentials.
#
# Usage:
#   source .env.github-scripts && node .github/scripts/unit-test-agent.js ...
#   source .env.github-scripts && node .github/scripts/jira-client.js CS-1234

# ── GitHub ────────────────────────────────────────────────────
# Personal access token with repo + pull_request read scope
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your_token_here

# ── Jira Cloud ────────────────────────────────────────────────
# Your Jira Cloud instance URL (no trailing slash)
JIRA_BASE_URL=https://goa-dio.atlassian.net

# Atlassian account email
JIRA_EMAIL=your.email@gov.ab.ca

# Atlassian API token (not your password)
# Create at: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=your_jira_api_token_here

# ── PR review script (only needed for local testing) ─────────
# Set these when running github-pr-clean-code-review.js locally
# PR_NUMBER=1234
# REPO_OWNER=GovAlta
# REPO_NAME=adsp-monorepo
# BASE_SHA=abc123
# HEAD_SHA=def456
